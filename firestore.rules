rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "baby.ayesha.shurli@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidPost(data) {
      return data.keys().hasAll(['content', 'author', 'timestamp']) &&
             data.keys().hasOnly(['content', 'author', 'timestamp', 'likes', 'commentsCount']) &&
             isValidString(data.content, 1, 2000) &&
             isValidString(data.author, 1, 50) &&
             data.timestamp is number;
    }

    // NGOs and Doctors are public read, admin write
    match /ngos/{ngoId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /doctors/{doctorId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Community posts are public read, anonymous create
    match /posts/{postId} {
      allow read: if true;
      allow create: if isValidPost(request.resource.data);
      allow update, delete: if false;
    }

    // Users collection (for roles)
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
